# ========================================
# DocScan Finance CR - Configuración
# ========================================

# SERVIDOR
PORT=3000

# CREDENCIALES DE CORREO (Gmail)
# Nota: Para Gmail, debes activar "Contraseña de Aplicación" (App Password)
# Pasos:
# 1. Ve a https://myaccount.google.com/security
# 2. Habilita "Verificación en dos pasos" si no lo está
# 3. Busca "Contraseña de Aplicación" en la página de seguridad
# 4. Selecciona "Mail" y "Windows Computer" (o tu dispositivo)
# 5. Google te generará una contraseña de 16 caracteres (sin espacios)
EMAIL_USER=tu-correo@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# DESTINO DEL REPORTE
EMAIL_DESTINO=jefe-aprobacion@empresa.com

# CONFIGURACIÓN DE IA (opcional, depende de tu servicio)
# Si usas Google Generative AI:
GOOGLE_API_KEY=tu-clave-google

# Si usas Anthropic Claude:
ANTHROPIC_API_KEY=tu-clave-anthropic
